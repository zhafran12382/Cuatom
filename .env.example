# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/aichat?schema=public"

# Encryption key for API keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY="change-this-to-a-32-byte-base64-secret"

# Request settings
DEFAULT_REQUEST_TIMEOUT_MS="90000"
MAX_PROMPT_CHARS="100000"
MAX_OUTPUT_TOKENS="8192"
